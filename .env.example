# Power BI Login (Microsoft account)
POWERBI_USERNAME=your-powerbi-email@domain.com
POWERBI_PASSWORD=your-powerbi-password

# Power BI Report URL (full URL from browser)
POWERBI_REPORT_URL=https://app.powerbi.com/groups/720de077-9471-4923-80f1-3352618c131d/reports/febba574-7c8f-4352-ae59-ebeb2b0f96de/ReportSection84fb5c2a3382b283c39f?experience=power-bi

# Gmail SMTP
GMAIL_ADDRESS=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password

# Recipient
RECIPIENT_EMAIL=recipient@example.com

# Set to "true" to run Chrome without a visible window (headless)
HEADLESS=false

# ── Cube.dev (analytics/wbr_pull.py) ─────────────────────────────────────────
# Base URL of the Cube.dev staging instance (no trailing slash)
CUBE_API_URL=https://casinetto.staging.cibos.dev

# Bearer token for Cube.dev API authentication
CUBE_API_TOKEN=your-cube-api-token-here
